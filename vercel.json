{
  "version": 2,
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "functions": {
    "api/router.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(?!router(?:\\?|$))(.*)",
      "destination": "/api/router?slug=$1"
    },
    { "source": "/", "destination": "/index.html" },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}

